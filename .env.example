# SaintPetter Auth — Backend environment variables (prefijo SPA_)
# Copia a .env y ajusta valores. No versionar .env.
# Ver también: local/scripts/dev-network.sh y local/scripts/setup-env.sh

# ── Requeridas ─────────────────────────────────────────────────────────────────
SPA_POSTGRES_URL=postgresql://user:password@127.0.0.1:5432/saintpetter_auth
SPA_REDIS_URL=redis://127.0.0.1:6379
SPA_FRONTEND_URL=http://localhost:5678

# ── Backend ───────────────────────────────────────────────────────────────────
SPA_BACKEND_PORT=4567
NODE_ENV=development

# ── Platform admin (seed asigna rol platform_admin a este email si el usuario existe) ──
SPA_PLATFORM_ADMIN_EMAIL=

# ── Google OAuth (opcional; omitir para deshabilitar login con Google) ─────────
SPA_GOOGLE_CLIENT_ID=
SPA_GOOGLE_CLIENT_SECRET=
SPA_GOOGLE_CALLBACK_URL=http://localhost:4567/auth/google/callback
SPA_GOOGLE_ALLOWED_REDIRECT_URIS=

# ── CORS (opcional; por defecto se usa SPA_FRONTEND_URL) ───────────────────────
# Lista separada por comas para varios orígenes: https://app1.com,https://app2.com
SPA_CORS_ORIGIN=

# ── Base de datos (opcional) ───────────────────────────────────────────────────
# SPA_USE_DB_SYNC=false desactiva TypeORM synchronize
SPA_USE_DB_SYNC=

# ── RabbitMQ (opcional; cola de notificaciones) ───────────────────────────────
SPA_RABBITMQ_URL=amqp://user:password@127.0.0.1:5672/

# ── SMTP (opcional; envío de emails) ───────────────────────────────────────────
SPA_SMTP_HOST=127.0.0.1
SPA_SMTP_PORT=1025
SPA_SMTP_USER=
SPA_SMTP_PASS=
SPA_SMTP_FROM=noreply@saintpetter.local
